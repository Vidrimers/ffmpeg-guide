@echo on
chcp 65001 >nul
setlocal enabledelayedexpansion

:checkArgs
if "%~1"=="" (
    echo Ошибка: нужно передать папку или файл.
    echo Положите ярлык этого скрипта в папку shell:sendto и выбирайте папку правой кнопкой.
    pause
    exit /b 1
)

where ffmpeg >nul 2>nul
if errorlevel 1 (
    echo Ошибка: ffmpeg не найден в PATH.
    pause
    exit /b 1
)

where ffprobe >nul 2>nul
if errorlevel 1 (
    echo Ошибка: ffprobe не найден в PATH.
    pause
    exit /b 1
)

set "target=%~1"
if exist "%target%\*" (
    set "folder=%~1"
) else if exist "%target%" (
    for %%F in ("%~1") do set "folder=%%~dpF"
) else (
    echo Ошибка: путь не найден: %~1
    pause
    exit /b 1
)

echo.
echo Скрипт запускается из: %~dp0
echo Целевая папка для обработки: %folder%
for /f %%x in ('dir /a:-d /b "%folder%" ^| find /c /v ""') do set "total_files_count=%%x"
set "img_count=0"
pushd "%folder%"
for %%f in (*.jpg *.jpeg *.png *.webp *.bmp *.gif *.tif *.tiff *.avif *.heic *.heif) do set /a img_count+=1
popd

echo Всего файлов в папке: %total_files_count%
echo Всего изображений: %img_count%
if %img_count% equ 0 (
    echo Нет изображений для обработки.
    pause
    exit /b 0
)

echo.
set "format_choice="
set "FORMAT_FILE=%temp%\format_choice_%RANDOM%.txt"
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
if exist "!FORMAT_FILE!" (
    set /p format_choice= < "!FORMAT_FILE!"
    del "!FORMAT_FILE!" 2>nul
)
set "output_ext="
set "format_mode=keep"
if defined format_choice (
    set "format_choice=!format_choice: =!"
    if /i "!format_choice!"=="same" set "format_mode=keep"
    if /i "!format_choice!"=="keep" set "format_mode=keep"
    if /i "!format_choice!"=="leave" set "format_mode=keep"
    if /i "!format_choice!"=="current" set "format_mode=keep"
    if /i "!format_choice!"=="jpg" set "output_ext=.jpg" & set "format_mode=convert"
    if /i "!format_choice!"=="jpeg" set "output_ext=.jpg" & set "format_mode=convert"
    if /i "!format_choice!"=="png" set "output_ext=.png" & set "format_mode=convert"
    if /i "!format_choice!"=="webp" set "output_ext=.webp" & set "format_mode=convert"
    if /i "!format_choice!"=="bmp" set "output_ext=.bmp" & set "format_mode=convert"
    if /i "!format_choice!"=="tif" set "output_ext=.tif" & set "format_mode=convert"
    if /i "!format_choice!"=="tiff" set "output_ext=.tiff" & set "format_mode=convert"
    if /i "!format_choice!"=="avif" set "output_ext=.avif" & set "format_mode=convert"
    if /i "!format_choice:~0,1!"=="." set "format_choice=!format_choice:~1!"
    if /i not "!format_mode!"=="keep" if not defined output_ext set "output_ext=.!format_choice!" & set "format_mode=convert"
)
if /i "!format_mode!"=="keep" (
    echo Формат вывода: оставить текущий.
) else (
    echo Формат вывода: !output_ext!
)

set "shutdown_choice=n"
echo Выключить ПК после завершения?
set "SHUTDOWN_FILE=%temp%\shutdown_choice_%RANDOM%.txt"
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
if exist "!SHUTDOWN_FILE!" (
    set /p shutdown_choice= < "!SHUTDOWN_FILE!"
    del "!SHUTDOWN_FILE!" 2>nul
)
echo Если файл уже существует в converted-img?
set "OVERWRITE_FILE=%temp%\overwrite_choice_%RANDOM%.txt"
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
if exist "!OVERWRITE_FILE!" (
    set /p overwrite_choice= < "!OVERWRITE_FILE!"
    del "!OVERWRITE_FILE!" 2>nul
)

set "quality_choice="
set "compression_choice="
set "quality_param="
set "compression_param="
set "scale_choice="
set "scale_filter="

if /i "!output_ext!"==".jpg" (
    echo Качество JPG ^(1-100^):
    set "QUALITY_FILE=%temp%\quality_choice_%RANDOM%.txt"
    powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
    if exist "!QUALITY_FILE!" (
        set /p quality_choice= < "!QUALITY_FILE!"
        del "!QUALITY_FILE!" 2>nul
    )
    if "!quality_choice!"=="" set "quality_choice=90"
    if !quality_choice! lss 1 set "quality_choice=1"
    if !quality_choice! gtr 100 set "quality_choice=100"
    set "quality_param=-q:v !quality_choice!"
) else if /i "!output_ext!"==".webp" (
    echo Качество WEBP ^(1-100^):
    set "QUALITY_FILE=%temp%\quality_choice_%RANDOM%.txt"
    powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
    if exist "!QUALITY_FILE!" (
        set /p quality_choice= < "!QUALITY_FILE!"
        del "!QUALITY_FILE!" 2>nul
    )
    if "!quality_choice!"=="" set "quality_choice=90"
    if !quality_choice! lss 1 set "quality_choice=1"
    if !quality_choice! gtr 100 set "quality_choice=100"
    set "quality_param=-q:v !quality_choice!"
) else if /i "!output_ext!"==".png" (
    echo Уровень сжатия PNG ^(0-100^):
    set "COMPRESSION_FILE=%temp%\compression_choice_%RANDOM%.txt"
    powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
    if exist "!COMPRESSION_FILE!" (
        set /p compression_choice= < "!COMPRESSION_FILE!"
        del "!COMPRESSION_FILE!" 2>nul
    )
    if "!compression_choice!"=="" set "compression_choice=100"
    if !compression_choice! lss 0 set "compression_choice=0"
    if !compression_choice! gtr 100 set "compression_choice=100"
    set "compression_param=-compression_level !compression_choice!"
) else if /i "!output_ext!"==".tif" (
    echo Сжатие TIFF:
    set "COMPRESSION_FILE=%temp%\compression_choice_%RANDOM%.txt"
    powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
    if exist "!COMPRESSION_FILE!" (
        set /p compression_choice= < "!COMPRESSION_FILE!"
        del "!COMPRESSION_FILE!" 2>nul
    )
    if "!compression_choice!"=="" set "compression_choice=lzw"
    set "compression_param=-compression !compression_choice!"
) else if /i "!output_ext!"==".tiff" (
    echo Сжатие TIFF:
    set "COMPRESSION_FILE=%temp%\compression_choice_%RANDOM%.txt"
    powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
    if exist "!COMPRESSION_FILE!" (
        set /p compression_choice= < "!COMPRESSION_FILE!"
        del "!COMPRESSION_FILE!" 2>nul
    )
    if "!compression_choice!"=="" set "compression_choice=lzw"
    set "compression_param=-compression !compression_choice!"
)

echo Выберите масштаб:
set "SCALE_FILE=%temp%\scale_choice_%RANDOM%.txt"
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  2>nul
if exist "!SCALE_FILE!" (
    set /p scale_choice= < "!SCALE_FILE!"
    del "!SCALE_FILE!" 2>nul
)
if not "!scale_choice!"=="" set "scale_filter=-vf scale=!scale_choice!"

echo.
if /i "%shutdown_choice%"=="y" (
    echo ВНИМАНИЕ: после завершения конвертации ПК будет выключен.
) else if /i "%shutdown_choice%"=="n" (
    echo ВНИМАНИЕ: ПК НЕ будет выключаться после завершения.
) else (
    echo ВНИМАНИЕ: ПК будет выключен через %shutdown_choice% минут после завершения.
)

echo.
set "overwrite_mode=ask"
set "overwrite_flag="
if /i "%overwrite_choice%"=="y" (
    set "overwrite_mode=overwrite"
    set "overwrite_flag=-y"
) else if /i "%overwrite_choice%"=="n" (
    set "overwrite_mode=skip"
)

:processNext
if "%~1"=="" goto end

set "target=%~1"
if exist "%target%\*" (
    set "folder=%~1"
) else if exist "%target%" (
    for %%F in ("%~1") do set "folder=%%~dpF"
) else (
    echo Пропускаю несуществующий путь: %~1
    shift
    goto processNext
)

pushd "%folder%"
setlocal enabledelayedexpansion
mkdir converted-img 2>nul
mkdir done-img 2>nul
mkdir animation 2>nul

set "log=conversion-img_report.txt"
set "total_files=0"
set "skipped_files=0"
set "skipped_list="

:: Время начала
set "start_time=%time%"
    for /f "tokens=1-3 delims=:,." %%a in ("%time%") do (
        set "h=%%a"
        set "h=!h: =!"
        if "!h:~0,1!"=="0" set "h=!h:~1!"
        set /a start_h=h
        set "m=%%b"
        if "!m:~0,1!"=="0" set "m=!m:~1!"
        set /a start_m=m
        set "s=%%c"
        if "!s:~0,1!"=="0" set "s=!s:~1!"
        set /a start_s=s
    )
set /a start_total=start_h*3600+start_m*60+start_s

echo ===================================== > %log%
echo  Отчёт конвертации изображений >> %log%
echo ===================================== >> %log%
echo Начало: %date% %start_time% >> %log%
echo. >> %log%
echo Файлы: >> %log%
echo --------------------------------------- >> %log%

for %%f in (*.jpg *.jpeg *.png *.webp *.bmp *.gif *.tif *.tiff *.avif *.heic *.heif) do (
    rem
    rem
 rem
    rem
    rem
    rem
    rem
    rem
    rem
 rem
